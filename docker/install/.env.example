# Paperclip Docker Environment
# Copy to .env and fill in required values before starting.
#
#   cp .env.example .env
#   # edit .env, then:
#   docker compose up -d
#
# Or use the setup script which auto-generates secrets:
#   ./setup.sh

# --- Required (generate before first start) ---
# Run: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Run: openssl rand -hex 16
POSTGRES_PASSWORD=

# --- Networking ---
PAPERCLIP_PORT=3100
# Set to the exact URL users will access in their browser.
# Examples:
#   http://localhost:3100
#   https://desk.example.com
# If behind a reverse proxy, set to the external HTTPS URL.
PAPERCLIP_PUBLIC_URL=

# --- Database ---
POSTGRES_USER=paperclip
POSTGRES_DB=paperclip

# --- Image version ---
# Override only if you want a different registry/repository.
PAPERCLIP_IMAGE=ghcr.io/ak-agi/paperclip
# Pin to a specific tag for reproducible deploys, e.g. "sha-abc1234"
PAPERCLIP_VERSION=latest

# --- Optional: AI adapter API keys ---
# Uncomment and fill in to enable local adapter runs inside the container.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
